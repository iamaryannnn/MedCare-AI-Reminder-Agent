# Database Configuration
DATABASE_URL=sqlite:///./medcare.db

# API Config
PORT=8000
HOST=0.0.0.0

# Twilio Configuration (Optional, falls back to logging)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# OpenAI & Azure OpenAI Configurations (Optional, falls back to local templates)
OPENAI_API_KEY=

# If using Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2023-05-15
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# SMTP Configuration (Optional, falls back to logging)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
